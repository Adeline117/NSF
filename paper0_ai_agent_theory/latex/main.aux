\@writefile{toc}{\contentsline {section}{\numberline {1}Understanding the On-Chain AI Agent: A Four-Condition Definition and Eight-Category Taxonomy Validated on 2,744 Ethereum Addresses}{1}{section.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {2}Abstract}{1}{section.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}1. Introduction}{1}{section.3}\protected@file@percent }
