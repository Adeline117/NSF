\newlabel{eq:fano}{{1}{3}{A Fano bound for AI agent detection}{equation.1}{}}
\citation{kraskov2004estimating}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Mutual information, conditional entropy, Fano accuracy ceiling, and measured classifier accuracy for three behavioral feature sets on $N=2{,}744$ agent addresses. $H(Y) = 1.697$ bits; $K = 8$ categories. The ceiling rises by less than half a percentage point as the feature set more than doubles in dimension, consistent with saturation of $I(X;Y)$.}}{4}{table.1}\protected@file@percent }
\newlabel{tab:ceiling}{{1}{4}{Mutual information, conditional entropy, Fano accuracy ceiling, and measured classifier accuracy for three behavioral feature sets on $N=2{,}744$ agent addresses. $H(Y) = 1.697$ bits; $K = 8$ categories. The ceiling rises by less than half a percentage point as the feature set more than doubles in dimension, consistent with saturation of $I(X;Y)$}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The information-theoretic ceiling for AI agent detection.} The Fano accuracy ceiling (solid) as a function of mutual information $I(X;Y)$, together with three measured feature sets ($X_{23}$, $X_{31}$, $X_{47}$) and the accuracy each achieves empirically (markers). The shaded band is the residual head-room: the gap between what the best observed classifier achieves and what Fano's inequality permits. At $X_{31}$ the head-room is $1.98$ percentage points.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:ceiling}{{1}{5}{\textbf {The information-theoretic ceiling for AI agent detection.} The Fano accuracy ceiling (solid) as a function of mutual information $I(X;Y)$, together with three measured feature sets ($X_{23}$, $X_{31}$, $X_{47}$) and the accuracy each achieves empirically (markers). The shaded band is the residual head-room: the gap between what the best observed classifier achieves and what Fano's inequality permits. At $X_{31}$ the head-room is $1.98$ percentage points}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Unsupervised clustering saturates at $2$--$3$ groups regardless of feature-set expressiveness.} K-Means silhouette across $k \in \{3, \dots  , 15\}$ peaks at $k = 3$ ($0.151$), with a secondary plateau at $k = 5$. HDBSCAN (density-based, no pre-specified $k$) finds two density clusters. The taxonomy's eight categories (colored markers in the inset PCA projection) do not separate in the unsupervised geometry.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:clustering}{{2}{6}{\textbf {Unsupervised clustering saturates at $2$--$3$ groups regardless of feature-set expressiveness.} K-Means silhouette across $k \in \{3, \dots , 15\}$ peaks at $k = 3$ ($0.151$), with a secondary plateau at $k = 5$. HDBSCAN (density-based, no pre-specified $k$) finds two density clusters. The taxonomy's eight categories (colored markers in the inset PCA projection) do not separate in the unsupervised geometry}{figure.2}{}}
\citation{yao2023react}
\citation{schick2023toolformer}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Execution time is a tool signature; decision interval is an agent signature.} Left panel: median DeFi execution time for LLM-driven agents (blue, $216$\,s) is \emph  {faster} than for rule-based DeFi managers (orange, $289$\,s)---Cohen's $d \approx 0$, indistinguishable in a $200$-address pilot. Right panel: the general inter-transaction interval is \emph  {slower} for LLM-driven agents ($441$\,s vs.\ $321$\,s; $d=1.01$ at $n=2{,}744$), the largest effect size in a $54$-feature battery. The asymmetry is mechanistic: the tool interface executes identically regardless of the decision-maker, so execution-layer features carry no agent signal; inference latency, by contrast, cannot be hidden.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:mechanism}{{3}{8}{\textbf {Execution time is a tool signature; decision interval is an agent signature.} Left panel: median DeFi execution time for LLM-driven agents (blue, $216$\,s) is \emph {faster} than for rule-based DeFi managers (orange, $289$\,s)---Cohen's $d \approx 0$, indistinguishable in a $200$-address pilot. Right panel: the general inter-transaction interval is \emph {slower} for LLM-driven agents ($441$\,s vs.\ $321$\,s; $d=1.01$ at $n=2{,}744$), the largest effect size in a $54$-feature battery. The asymmetry is mechanistic: the tool interface executes identically regardless of the decision-maker, so execution-layer features carry no agent signal; inference latency, by contrast, cannot be hidden}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Cross-chain validation on Polygon proof-of-stake ($n = 29$ addresses).} Top: direct transfer of an Ethereum-trained classifier to Polygon yields $22.2\%$ five-class accuracy, barely above the $20\%$ random baseline; re-training on Polygon yields $51.7\%$. Bottom: the Polygon gas-price and inter-transaction interval distributions are structurally compressed relative to Ethereum (near-constant $\sim $$30$ gwei fees; $2$-second block time), consistent with an information-theoretic bound that is intrinsically tighter on Polygon than on Ethereum.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:crosschain}{{4}{9}{\textbf {Cross-chain validation on Polygon proof-of-stake ($n = 29$ addresses).} Top: direct transfer of an Ethereum-trained classifier to Polygon yields $22.2\%$ five-class accuracy, barely above the $20\%$ random baseline; re-training on Polygon yields $51.7\%$. Bottom: the Polygon gas-price and inter-transaction interval distributions are structurally compressed relative to Ethereum (near-constant $\sim $$30$ gwei fees; $2$-second block time), consistent with an information-theoretic bound that is intrinsically tighter on Polygon than on Ethereum}{figure.4}{}}
